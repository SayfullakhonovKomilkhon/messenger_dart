# ===== PostgreSQL =====
POSTGRES_DB=messenger
POSTGRES_USER=messenger_user
POSTGRES_PASSWORD=

# ===== Redis =====
REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD@localhost:6379

# ===== Backend =====
DATABASE_URL=jdbc:postgresql://localhost:5432/messenger
PORT=3000

# ===== JWT =====
JWT_SECRET=
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_EXPIRES=2592000

# ===== Cloudflare R2 (файловое хранилище) =====
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=messenger-files
R2_PUBLIC_URL=https://pub-<HASH>.r2.dev
FILE_MAX_SIZE_BYTES=104857600

# ===== Firebase FCM (push-уведомления) =====
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ===== TURN сервер (WebRTC звонки) =====
TURN_USERNAME=turnuser
TURN_PASSWORD=
TURN_REALM=messenger.local
